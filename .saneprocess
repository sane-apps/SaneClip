# SaneProcess compliance manifest
name: SaneClip
type: macos_app
scheme: SaneClip
project: SaneClip.xcodeproj
bundle_id: com.saneclip.app

build:
  xcodegen: true

release:
  team_id: M78L6FXD48
  signing_identity: "Developer ID Application"
  dist_host: dist.saneclip.com
  site_host: saneclip.com
  r2_bucket: sanebar-downloads
  use_sparkle: true
  min_system_version: "15.0"
  dmg:
    volume_icon: Resources/DMGIcon.icns
    file_icon: Resources/DMGIcon.icns
    window_size: "600 428"
    app_icon_pos: "150 190"
    drop_pos: "450 190"
    no_internet_enable: true
  export:
    profiles:
      - "com.saneclip.app:SaneClip Developer ID"
      - "com.saneclip.app.widgets:SaneClip Widgets Developer ID"

commands:
  verify: ./scripts/SaneMaster.rb verify
  test_mode: ./scripts/SaneMaster.rb tm
  lint: ./scripts/SaneMaster.rb lint
  clean: ./scripts/SaneMaster.rb clean
  launch: ./scripts/SaneMaster.rb launch
  logs: ./scripts/SaneMaster.rb logs

docs:
  - CLAUDE.md
  - README.md
  - DEVELOPMENT.md
  - ARCHITECTURE.md
  - SESSION_HANDOFF.md

mcps:
  - apple-docs
  - context7
  - github
  - xcode

appstore:
  enabled: true
  app_id: "6758898132"
  product_id: "com.saneclip.app.pro.unlock"
  configuration: Release-AppStore
  platforms: [macos, ios]
  ios_scheme: SaneClipIOS
  category: public.app-category.productivity
  age_rating: "4+"
  privacy_policy_url: "https://saneclip.com/privacy"
  support_url: "https://saneclip.com/support"
  marketing_url: "https://saneclip.com"
  metadata:
    macos:
      subtitle: "Private Clipboard Manager"
      promotional_text: "Fast searchable clipboard history with on-device privacy. Pro adds Touch ID lock, AES-256 encryption, snippets, and paste stack."
      description: >-
        SaneClip gives you fast clipboard history with search, pinning, and keyboard-first paste so repeated work takes seconds instead of minutes.
        Your data stays local, with optional Pro security features like Touch ID history lock and AES-256 encryption at rest.
        Build a reliable personal workflow with snippets, paste stack, and transforms that run entirely on your Mac.
      keywords: "clipboard,copy paste,history,snippets,touch id,security,productivity,mac utility"
      whats_new: "Improved sync and search performance, stronger reliability for history operations, and stability updates."
      marketing_url: "https://saneclip.com"
    ios:
      subtitle: "Clipboard History + Widgets"
      promotional_text: "Search and reuse copied text instantly with iCloud sync and widgets. Pro adds encryption, snippets, and advanced paste tools."
      description: >-
        SaneClip keeps your clipboard history organized across iPhone, iPad, and Mac so important text is always within reach.
        Search, pin, and reuse clips instantly with keyboard-friendly actions, Home Screen widgets, and iCloud sync.
        Pro unlock adds encryption, snippets, transforms, and advanced paste workflows while keeping data private on-device.
      keywords: "clipboard,copy paste,history,widgets,icloud,snippets,productivity,notes"
      whats_new: "Faster history refresh, better sync stability, and reliability improvements across clipboard actions."
      marketing_url: "https://saneclip.com"
  review_notes: "SaneClip App Store build does not request Accessibility access and does not simulate keyboard events. Selecting a clipboard item copies it to the clipboard and shows a local notification asking the user to press Cmd+V manually in the frontmost app. To test: open history with Cmd+Shift+V, select any item, then paste with Cmd+V."
  accessibility_declarations:
    publish: true
    mac:
      supports_dark_interface: true
    iphone:
      supports_dark_interface: true
    ipad:
      supports_dark_interface: true
  screenshots:
    macos: docs/images/screenshot-[!i]*.png
    ios: docs/images/screenshot-ios-*-dark.png
    ipad: docs/images/screenshot-ipad-*-dark.png
  strip_frameworks:
    - Sparkle.framework
  contact:
    name: "Stephan Joseph"
    phone: "+17277589785"
    email: "hi@saneapps.com"

website: true
website_domain: saneclip.com
