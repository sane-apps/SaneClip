# SaneProcess compliance manifest
name: SaneClip
type: macos_app
scheme: SaneClip
project: SaneClip.xcodeproj
bundle_id: com.saneclip.app

build:
  xcodegen: true

release:
  team_id: M78L6FXD48
  signing_identity: "Developer ID Application"
  dist_host: dist.saneclip.com
  site_host: saneclip.com
  r2_bucket: sanebar-downloads
  use_sparkle: true
  min_system_version: "15.0"
  dmg:
    volume_icon: Resources/DMGIcon.icns
    file_icon: Resources/DMGIcon.icns
    window_size: "600 428"
    app_icon_pos: "150 190"
    drop_pos: "450 190"
    no_internet_enable: true
  export:
    profiles:
      - "com.saneclip.app:SaneClip Developer ID"
      - "com.saneclip.app.widgets:SaneClip Widgets Developer ID"

cloudkit:
  enabled: true
  container_id: iCloud.com.saneclip.app
  team_id: M78L6FXD48
  required_record_types:
    - ClipboardItem

commands:
  verify: ./scripts/SaneMaster.rb verify
  test_mode: ./scripts/SaneMaster.rb tm
  lint: ./scripts/SaneMaster.rb lint
  clean: ./scripts/SaneMaster.rb clean
  launch: ./scripts/SaneMaster.rb launch
  logs: ./scripts/SaneMaster.rb logs

docs:
  - CLAUDE.md
  - README.md
  - DEVELOPMENT.md
  - ARCHITECTURE.md
  - SESSION_HANDOFF.md

mcps:
  - apple-docs
  - context7
  - github
  - xcode

appstore:
  enabled: true
  app_id: "6758898132"
  product_id: "com.saneclip.app.pro.unlock"
  configuration: Release-AppStore
  platforms: [macos, ios]
  ios_scheme: SaneClipIOS
  category: public.app-category.productivity
  age_rating: "4+"
  privacy_policy_url: "https://saneclip.com/privacy"
  support_url: "https://saneclip.com/support"
  marketing_url: "https://saneclip.com"
  metadata:
    macos:
      subtitle: "Private Clipboard Manager"
      promotional_text: "Fast private clipboard history for Mac with search, pinning, snippets, and one-time Pro unlock."
      description: >-
        SaneClip gives you fast clipboard history on Mac with search, pinning, snippets, widgets, and privacy-first defaults.
        Keep important clips close, find old copies instantly, and build a cleaner repeatable workflow without handing your data to a third party.
        Pro adds Touch ID history lock, AES-256 encryption at rest, paste stack, transforms, clipboard rules, and unlimited history with a one-time unlock.
      keywords: "clipboard,copy paste,history,snippets,touch id,security,productivity,mac utility"
      whats_new: "Fixes iCloud sync rollout and production schema issues, improves update reliability, and fixes edit-field keyboard shortcut handling."
      marketing_url: "https://saneclip.com"
    ios:
      subtitle: "Clipboard History + Widgets"
      promotional_text: "Search, pin, and reuse synced clipboard history on iPhone and iPad with widgets and private iCloud sync."
      description: >-
        SaneClip brings your clipboard history from Mac to iPhone and iPad with private iCloud sync, fast search, pinning, and clean widgets.
        Browse your recent clips, copy them again in one tap, save new text and links from the Share Sheet, and keep important items pinned across devices.
        Pro adds encryption and more advanced workflows while keeping your data on your own devices instead of a third-party server.
      keywords: "clipboard,copy paste,history,widgets,icloud,snippets,productivity,notes"
      whats_new: "Fixes iCloud sync startup, preserves local history more reliably, and improves clipboard action stability."
      marketing_url: "https://saneclip.com"
  review_notes: "SaneClip App Store build does not request Accessibility access and does not simulate keyboard events. Selecting a clipboard item copies it to the clipboard and shows a local notification asking the user to press Cmd+V manually in the frontmost app. To test: open history with Cmd+Shift+V, select any item, then paste with Cmd+V. Basic is free. Pro is a one-time in-app purchase. No external checkout links or license keys are used in the App Store build."
  review_notes_by_platform:
    macos: "SaneClip for macOS App Store does not request Accessibility access and does not simulate keyboard events. Selecting a clipboard item copies it to the clipboard and shows a local notification asking the user to paste manually. To test: copy any text in TextEdit or Safari, open history with Cmd+Shift+V, select the copied item, then paste in another app with Cmd+V. If the history is empty on first launch, copy one line of text first and reopen the history window. Basic is free. Pro is a one-time in-app purchase. No external checkout links or license keys are used in the App Store build."
    ios: "SaneClip for iPhone and iPad does not request Accessibility, Apple Events, camera, microphone, or location permissions. The app displays clipboard history synced through the user's private iCloud account, supports search and pinning, and can save shared text or URLs through the iOS Share Sheet. If there is no synced history yet, the app shows built-in sample or demo history automatically so App Review can inspect the interface immediately. Basic is free. Pro is a one-time in-app purchase. No external checkout links or license keys are used in the App Store build."
  accessibility_declarations:
    publish: true
    mac:
      supports_dark_interface: true
    iphone:
      supports_dark_interface: true
    ipad:
      supports_dark_interface: true
  screenshots:
    macos: docs/images/screenshot-[!i]*.png
    ios: docs/images/screenshot-ios-*-dark.png
    ipad: docs/images/screenshot-ipad-*-dark.png
  strip_frameworks:
    - Sparkle.framework
  contact:
    name: "Stephan Joseph"
    phone: "+17277589785"
    email: "hi@saneapps.com"

website: true
website_domain: saneclip.com
