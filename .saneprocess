# SaneProcess compliance manifest
name: SaneClip
type: macos_app
scheme: SaneClip
project: SaneClip.xcodeproj
bundle_id: com.saneclip.app

build:
  xcodegen: true

tests:
  unit_dir: SaneClipTests
  unit_target: SaneClipTests

release:
  team_id: M78L6FXD48
  signing_identity: "Developer ID Application"
  dist_host: dist.saneclip.com
  site_host: saneclip.com
  r2_bucket: sanebar-downloads
  use_sparkle: true
  min_system_version: "15.0"
  dmg:
    volume_icon: Resources/DMGIcon.icns
    file_icon: Resources/DMGIcon.icns
    window_size: "600 428"
    app_icon_pos: "150 190"
    drop_pos: "450 190"
    no_internet_enable: true
  export:
    profiles:
      - "com.saneclip.app:SaneClip Developer ID"
      - "com.saneclip.app.widgets:SaneClip Widgets Developer ID"

cloudkit:
  enabled: true
  container_id: iCloud.com.saneclip.app
  team_id: M78L6FXD48
  required_record_types:
    - ClipboardItem

commands:
  verify: ./scripts/SaneMaster.rb verify
  test_mode: ./scripts/SaneMaster.rb tm
  lint: ./scripts/SaneMaster.rb lint
  clean: ./scripts/SaneMaster.rb clean
  launch: ./scripts/SaneMaster.rb launch
  logs: ./scripts/SaneMaster.rb logs

docs:
  - CLAUDE.md
  - README.md
  - DEVELOPMENT.md
  - ARCHITECTURE.md
  - SESSION_HANDOFF.md

mcps:
  - apple-docs
  - context7
  - github
  - xcode

appstore:
  enabled: true
  app_id: "6758898132"
  product_id: "com.saneclip.app.pro.unlock"
  scheme: SaneClip-AppStore
  configuration: Release-AppStore
  platforms: [macos, ios]
  ios_scheme: SaneClipIOS
  category: public.app-category.productivity
  age_rating: "4+"
  privacy_policy_url: "https://saneclip.com/privacy"
  support_url: "https://saneclip.com/support"
  marketing_url: "https://saneclip.com"
  metadata:
    macos:
      subtitle: "Private Clipboard Manager"
      promotional_text: "Free download includes clipboard history, search, pinning, screenshots, privacy-first defaults, and the iPhone/iPad companion app. Optional one-time Pro unlock adds OCR capture and advanced paste tools."
      description: >-
        SaneClip is a free Mac clipboard manager with a core included feature set and an optional one-time Pro unlock.
        The free download includes clipboard history for up to 50 items, standard paste, search, source-aware filtering,
        pinning, screenshot capture into history, excluded apps, auto-delete, the free iPhone and iPad companion app with
        optional private iCloud sync, and privacy-first defaults.
        The optional Pro unlock adds OCR capture for text grabs and searchable screenshot sidecars, unlimited history,
        Touch ID history lock, AES-256 encryption at rest, paste as plain text, smart paste, text transforms, paste stack,
        snippets, item notes, clipboard rules, and export/import.
      keywords: "clipboard,copy paste,history,snippets,touch id,security,productivity,mac utility"
      whats_new: "Adds a redesigned onboarding flow with clearer Basic vs Pro guidance, improves Accessibility and Screen Recording setup for capture workflows, and makes capture permissions easier to recover if you skipped them the first time."
      marketing_url: "https://saneclip.com"
    ios:
      subtitle: "Clipboard History + Widgets"
      promotional_text: "Search, pin, and reuse synced clipboard history on iPhone and iPad with widgets, source-aware colors, and private iCloud sync."
      description: >-
        SaneClip brings your clipboard history from Mac to iPhone and iPad with private iCloud sync, fast search, pinning, and clean widgets.
        Browse your recent clips, copy them again in one tap, save new text and links from the Share Sheet, and keep important items pinned across devices.
        Pro adds encryption and more advanced workflows while keeping your data on your own devices instead of a third-party server.
      keywords: "clipboard,copy paste,history,widgets,icloud,snippets,productivity,notes"
      whats_new: "Keeps the mobile UI aligned with the refreshed Mac onboarding and setup flow while preserving the color-coded source indicators and private iCloud sync experience."
      marketing_url: "https://saneclip.com"
  review_notes: "SaneClip is a freemium App Store app. Basic is free in the App Store build. SaneClip Pro Unlock is an optional one-time non-consumable StoreKit in-app purchase. No external checkout links or license keys are used in the App Store build."
  iap:
    display_name: "SaneClip Pro Unlock"
    price_usd: 14.99
    description: "Unlock OCR capture, unlimited history, and advanced clipboard tools."
    review_note: "SaneClip Pro Unlock is a one-time non-consumable StoreKit purchase. It adds OCR capture, unlimited history, Touch ID lock, encryption, snippets, paste as plain text, smart paste, text transforms, paste stack, notes, rules, and export/import. No external checkout links or license keys are used."
  review_notes_by_platform:
    macos: "SaneClip for macOS is a freemium Mac App Store app. Basic is free in the App Store build. The free download includes clipboard history for up to 50 items, standard paste, search, source-aware filtering, pinning, screenshot capture into history, excluded apps, auto-delete, the free iPhone and iPad companion app with optional private iCloud sync, and privacy-first defaults. The optional non-consumable in-app purchase SaneClip Pro Unlock ($14.99 once) adds OCR capture for text grabs and searchable screenshot sidecars, unlimited history, Touch ID history lock, AES-256 encryption at rest, paste as plain text, smart paste, text transforms, paste stack, snippets, item notes, clipboard rules, and export/import. The standard App Review flow does not require granting Accessibility or Apple Events permissions. Selecting a clipboard item copies it to the clipboard and shows a local notification asking the reviewer to paste manually with Cmd+V. To test: copy any text in TextEdit or Safari, open history with Cmd+Shift+V, select the copied item, then paste in another app with Cmd+V. Screenshot capture is available in Basic. OCR capture is visible as a locked Pro upgrade surface. No external checkout links or license keys are used in this build."
    ios: "SaneClip for iPhone and iPad is a freemium App Store app. Basic is free in the App Store build. The free download includes synced clipboard history, search, pinning, widgets, and Share Sheet saving. The optional one-time in-app purchase unlocks Pro features. The app does not request Accessibility, Apple Events, camera, microphone, or location permissions. Fastest review path: launch the app and leave onboarding visible, then inspect the optional Pro unlock on the final plan screen before tapping Continue. If onboarding has already been dismissed, open the Settings tab and return to the locked Pro surfaces in History or Pinned to inspect the visible upgrade path. If there is no synced history yet, the app shows built-in sample or demo history automatically so App Review can inspect the interface immediately. No external checkout links or license keys are used in the App Store build."
  accessibility_declarations:
    publish: true
    mac:
      supports_dark_interface: true
    iphone:
      supports_dark_interface: true
    ipad:
      supports_dark_interface: true
  screenshots:
    macos: docs/images/screenshot-[!i]*.png
    ios: docs/images/screenshot-ios-*-dark.png
    ipad: docs/images/screenshot-ipad-*-dark.png
  strip_frameworks:
    - Sparkle.framework
  contact:
    name: "Stephan Joseph"
    phone: "+17277589785"
    email: "hi@saneapps.com"

website: true
website_domain: saneclip.com
