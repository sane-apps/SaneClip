# SaneProcess compliance manifest
name: SaneClip
type: macos_app
scheme: SaneClip
project: SaneClip.xcodeproj
bundle_id: com.saneclip.app

build:
  xcodegen: true

tests:
  unit_dir: SaneClipTests
  unit_target: SaneClipTests

release:
  team_id: M78L6FXD48
  signing_identity: "Developer ID Application"
  dist_host: dist.saneclip.com
  site_host: saneclip.com
  r2_bucket: sanebar-downloads
  use_sparkle: true
  min_system_version: "14.0"
  reviewed_auto_reconcile_stashes:
    - stash_sha: "b5e4c5992a474829a159275d7e2e5b8b87b11c1b"
      subject: "On main: auto-reconcile-20260508-215519-stephans-mac-mini"
      decision: deferred
      reason: "Reviewed 2026-05-09. Mixed hotfix lane. Current HEAD already has the edit/save, snippet visibility, shortcut reset, capture wording, and update-row fixes, while this stash also reintroduces macOS 26-only SCScreenshotConfiguration/captureScreenshot(...) and older 2.3.0/default-encryption copy. Keep it out of direct v2.3.3."
    - stash_sha: "356fd5a95016c30c7c577ac203d471f26368cd33"
      subject: "On main: auto-reconcile-20260507-215520-stephans-mac-mini"
      decision: deferred
      reason: "Reviewed 2026-05-09. Setapp-only lane work: Setapp entitlements/README changes plus project metadata rewound to 2.3.0. Not needed for the direct v2.3.3 hotfix; handle in the Setapp lane."
    - stash_sha: "7153e8846e314948ded579cee71c903daa840607"
      subject: "On main: auto-reconcile-20260506-215521-stephans-mac-mini"
      decision: deferred
      reason: "Reviewed 2026-05-09. Setapp lane scaffolding in .saneprocess, scheme/project config, and collateral. Separate from the direct-download crash hotfix and still needs its own Setapp verification path."
    - stash_sha: "321ae3930ca7a0c29dd32bc9ade1c4af2fa8b252"
      subject: "On main: auto-reconcile-20260430-215517-stephans-mac-mini"
      decision: superseded
      reason: "Reviewed 2026-05-09. Older pre-2.3.3 state. It drops the batch-edit, capture wording, and shortcut-reset assertions and rewrites docs/index.html back to 2.3.0. Current HEAD/appcast already cover the shipped direct-release behavior."
    - stash_sha: "b2347f23c00d14be53a6daab772ead6514b1b3d2"
      subject: "On main: auto-reconcile-20260430-055519-stephans-mac-mini"
      decision: superseded
      reason: "Reviewed 2026-05-09. Project-file-only rollback to 2.3.0/2300 with stale icon wiring. Superseded by current 2.3.3 project metadata and live release state."
    - stash_sha: "13fce12306da6bf65167f9a2c503d69772e5f5cb"
      subject: "On main: auto-reconcile-20260429-215516-stephans-mac-mini"
      decision: deferred
      reason: "Reviewed 2026-05-09. Large alternate Setapp/iOS/settings refactor. Includes iOS URL-scheme/onboarding hooks and a major settings split that is not required for the direct crash hotfix. Needs a separate lane-specific pass."
    - stash_sha: "2e0224d11574569450eb413f91f130ae783e857a"
      subject: "On main: auto-reconcile-20260428-215521-stephans-mac-mini"
      decision: deferred
      reason: "Reviewed 2026-05-09. iOS plus Setapp collateral only: iOS URL-scheme/onboarding-page support, Setapp key enforcement, and older version metadata. Separate App Store/Setapp lane, not direct v2.3.3."
    - stash_sha: "05c534eee11ca73929009e691137cc58ba394b09"
      subject: "On main: auto-reconcile-20260425-215520-stephans-mac-mini"
      decision: superseded
      reason: "Reviewed 2026-05-09. SESSION_HANDOFF-only rollback to 2026-04-25 / v2.3.0. Current handoff includes the May 9 release-readiness and #688 crash context, so this stash is stale."
    - stash_sha: "570f66be5fe2c664f6d40d65849b6583ea7a8f7e"
      subject: "On main: auto-reconcile-20260424-215517-stephans-mac-mini"
      decision: superseded
      reason: "Reviewed 2026-05-09. docs/index.html-only rollback of website softwareVersion from 2.3.3 to 2.3.0. Current direct-release docs already point at 2.3.3."
    - stash_sha: "567f37bee3c1b07a9f2da98ac2b81f25bb926836"
      subject: "On main: auto-reconcile-20260424-153452-stephans-mac-mini"
      decision: superseded
      reason: "Reviewed 2026-05-09. Older website/appcast/privacy metadata train. Rewinds appcast/download links and comparison copy away from the live 2.3.3 direct channel and newer privacy disclosures."
    - stash_sha: "e139a73b7ee399917e4aeb03452f34bc980b930b"
      subject: "On main: auto-reconcile-20260423-215519-stephans-mac-mini"
      decision: superseded
      reason: "Reviewed 2026-05-09. Very old capture train. Relative to HEAD it predates the current capture/OCR implementation and the no-SCScreenshotConfiguration hotfix assertions, so it should not land in the direct v2.3.3 release."
    - stash_sha: "14e71f83362d8b3dc7c8c46ed583419355c9ca23"
      subject: "On main: auto-reconcile-20260508-215529-stephans-macbook-air"
      decision: deferred
      reason: "Reviewed 2026-05-09. Hotfix-critical pieces for edit/save mirrors, snippets visibility, shortcut reset, capture permission recovery, direct update rows, and GitHub #9-#12 are represented in current code/tests. Remaining docs/project collateral is deferred, and the macOS 26 SCScreenshotConfiguration path is intentionally superseded by the compatibility-safe SCScreenshotManager.captureImage implementation after email #688 proved the newer class caused dyld launch crashes on supported macOS 15."
    - stash_sha: "b7f4d97b20199ddc4ea5f7b350c49958eeabba4d"
      subject: "On main: auto-reconcile-20260507-215529-stephans-macbook-air"
      decision: deferred
      reason: "Reviewed 2026-05-09. Setapp security/keychain and Setapp public-key collateral is not part of the direct-download crash hotfix release candidate; keep it for the Setapp lane instead of mixing it into the urgent direct release."
    - stash_sha: "c3195ebc86bb5bf7796986751eb05f4753d815a4"
      subject: "On main: auto-reconcile-20260506-215531-stephans-macbook-air"
      decision: deferred
      reason: "Reviewed 2026-05-09. Setapp Info.plist/project/scheme/app icon lane work is intentionally deferred from the direct-download hotfix release; Setapp submission must run its own preflight before any Setapp upload."
    - stash_sha: "f48252ee117e5372a7299a9e300d2d4231fbe07d"
      subject: "On main: auto-reconcile-20260501-215526-stephans-macbook-air"
      decision: superseded
      reason: "Reviewed 2026-05-09. Small telemetry/test collateral is stale for this direct crash hotfix; current customer-facing edit/save coverage is already handled by later code and tests."
    - stash_sha: "b5bfec010a52a940e35fd1c1480d879e8a6f7ad9"
      subject: "On main: auto-reconcile-20260430-215529-stephans-macbook-air"
      decision: recovered
      reason: "Reviewed 2026-05-09. The customer-facing README, settings, website, and changelog release-note content for edit/save, capture wording, snippets, and shortcut reset is represented in the current release candidate and appcast notes."
    - stash_sha: "fcdeb789ff18abe43ff46b24a6a7c0a72308c808"
      subject: "On main: auto-reconcile-20260429-215525-stephans-macbook-air"
      decision: deferred
      reason: "Reviewed 2026-05-09. Large Setapp/UI settings split and screenshot collateral is not part of the direct-download crash hotfix; it must be handled as a separate Setapp/settings refactor with fresh visual verification."
    - stash_sha: "f81f808c5a0b1dbb23ffb60b1ed39603d3097c95"
      subject: "On main: auto-reconcile-20260428-215531-stephans-macbook-air"
      decision: deferred
      reason: "Reviewed 2026-05-09. iOS/Setapp screenshot/public-key collateral is not required for the direct Mac crash hotfix and remains a separate lane."
    - stash_sha: "4311d9149b74a870cac2f9a09f9ef39f7b0d3e5d"
      subject: "On main: auto-reconcile-20260425-215529-stephans-macbook-air"
      decision: recovered
      reason: "Reviewed 2026-05-09. Privacy policy collateral for aggregate app counts and website analytics has been restored in PRIVACY.md and docs/privacy.html and covered by public-docs tests."
    - stash_sha: "bbe87d36ba56a51220839d15df56c85d4d3750f0"
      subject: "On main: auto-reconcile-20260423-215529-stephans-macbook-air"
      decision: deferred
      reason: "Reviewed 2026-05-09. Older OCR/capture/searchability train is not tied to email #688 or GitHub #9-#12. Keep it out of the direct crash hotfix; the release candidate intentionally avoids macOS 26-only screenshot APIs."
    - stash_sha: "c8ca6ecc1ce86103fa3e54ede612e2105937681d"
      subject: "On main: auto-reconcile-20260424-153503-stephans-macbook-air"
      decision: recovered
      reason: "Reviewed 2026-05-09. Research cache note only; durable findings have been reflected in SESSION_HANDOFF and current release checks."
    - stash_sha: "fb581bed6f1daab0bb78912550982814be3fbdf7"
      subject: "On main: auto-reconcile-20260418-055526-stephans-macbook-air"
      decision: deferred
      reason: "Reviewed 2026-05-09. App Store screenshot/storyboard and SEO guide collateral is not part of the direct-download hotfix candidate. App Store submission must run its own screenshot/preflight lane before upload."
    - stash_sha: "5eec9156cb5fcc0fa954b27485d4832a687468b9"
      subject: "On main: auto-reconcile-20260413-215540-stephans-macbook-air"
      decision: superseded
      reason: "Reviewed 2026-05-09. Old .gitignore/.claude settings residue is superseded by current shared SaneProcess ignore and Codex policy."
    - stash_sha: "fbcc927c34ee159fe4784148ac48ab3e645d1504"
      subject: "On main: auto-reconcile-20260411-055525-stephans-macbook-air"
      decision: superseded
      reason: "Reviewed 2026-05-09. Old .gitignore/.claude settings residue is superseded by current shared SaneProcess ignore and Codex policy."
    - stash_sha: "9ca752c7d87ae81d1df20f4883f41d6001ba6a56"
      subject: "On main: auto-reconcile-20260410-215527-stephans-macbook-air"
      decision: superseded
      reason: "Reviewed 2026-05-09. Old .gitignore residue is superseded by current canonical shared ignore rules."
  dmg:
    volume_icon: Resources/DMGIcon.icns
    file_icon: Resources/DMGIcon.icns
    window_size: "600 428"
    app_icon_pos: "150 190"
    drop_pos: "450 190"
    no_internet_enable: true
  export:
    profiles:
      - "com.saneclip.app:SaneClip Developer ID"
      - "com.saneclip.app.widgets:SaneClip Widgets Developer ID"

cloudkit:
  enabled: true
  container_id: iCloud.com.saneclip.app
  team_id: M78L6FXD48
  required_record_types:
    - ClipboardItem

commands:
  verify: ./scripts/SaneMaster.rb verify
  test_mode: ./scripts/SaneMaster.rb tm
  lint: ./scripts/SaneMaster.rb lint
  clean: ./scripts/SaneMaster.rb clean
  launch: ./scripts/SaneMaster.rb launch
  logs: ./scripts/SaneMaster.rb logs

docs:
  - CLAUDE.md
  - README.md
  - DEVELOPMENT.md
  - ARCHITECTURE.md
  - SESSION_HANDOFF.md

mcps:
  - apple-docs
  - context7
  - github
  - xcode

appstore:
  enabled: true
  app_id: "6758898132"
  product_id: "com.saneclip.app.pro.unlock"
  scheme: SaneClip-AppStore
  configuration: Release-AppStore
  platforms: [macos, ios]
  ios_scheme: SaneClipIOS
  category: public.app-category.productivity
  age_rating: "4+"
  copyright: "2026 SaneApps"
  content_rights_declaration: DOES_NOT_USE_THIRD_PARTY_CONTENT
  export_compliance:
    uses_non_exempt_encryption: false
    exemption_reason: "SaneClip uses Apple platform security and standard Apple-provided cryptography for local user data protection; it does not use non-exempt or proprietary encryption."
  privacy_policy_url: "https://saneclip.com/privacy"
  support_url: "https://saneclip.com/support"
  marketing_url: "https://saneclip.com"
  metadata:
    macos:
      subtitle: "Private Clipboard Manager"
      promotional_text: "Free clipboard history with privacy-first defaults: no clipboard-content upload to SaneApps, optional iCloud sync, and Pro encryption."
      description: >-
        SaneClip is a free Mac clipboard manager with a core included feature set and an optional one-time Pro unlock.
        The free download includes clipboard history for up to 50 items, standard paste, search, source-aware filtering,
        pinning, screenshot capture into history, excluded apps, auto-delete, the free iPhone and iPad companion app with
        optional iCloud sync through your own iCloud account, no clipboard-content upload to SaneApps servers,
        and privacy-first defaults.
        The optional Pro unlock adds OCR capture for text grabs and searchable screenshot sidecars, unlimited history,
        Touch ID history lock, AES-GCM history encryption at rest and encrypted sync payloads before upload,
        paste as plain text, smart paste, text transforms, paste stack, snippets, item notes, clipboard rules, and export/import.
      keywords: "clipboard,copy paste,history,snippets,touch id,security,productivity,mac utility"
      whats_new: "Improves history focus after pasting with keep-open enabled and keeps compact history controls stable across window sizes."
      marketing_url: "https://saneclip.com"
    ios:
      subtitle: "Clipboard History + Widgets"
      promotional_text: "Search, pin, and reuse synced clipboard history on iPhone and iPad. Sync uses your own iCloud account, not a SaneApps server."
      description: >-
        SaneClip brings your clipboard history from Mac to iPhone and iPad with iCloud sync through your own account, fast search, pinning, and clean widgets.
        Browse your recent clips, copy them again in one tap, save new text and links from the Share Sheet, and keep important items pinned across devices.
        Clipboard contents are never sent to SaneApps servers. Pro adds encryption and more advanced workflows, including encrypted sync payloads before upload when History Encryption is enabled.
      keywords: "clipboard,copy paste,history,widgets,icloud,snippets,productivity,notes"
      whats_new: "Improves shared history reliability and keeps the companion app aligned with the current SaneClip stability release."
      marketing_url: "https://saneclip.com"
  review_notes: "SaneClip is a freemium App Store app. Basic is free in the App Store build. SaneClip Pro Unlock is an optional one-time non-consumable StoreKit in-app purchase. No external checkout links or license keys are used in the App Store build."
  iap:
    display_name: "SaneClip Pro Unlock"
    price_usd: 14.99
    description: "Unlock OCR capture, unlimited history, and advanced clipboard tools."
    review_note: "SaneClip Pro Unlock is a one-time non-consumable StoreKit purchase. It adds OCR capture, unlimited history, Touch ID lock, encryption, snippets, paste as plain text, smart paste, text transforms, paste stack, notes, rules, and export/import. No external checkout links or license keys are used."
  review_notes_by_platform:
    macos: >-
      SaneClip for macOS is a freemium Mac App Store app. Basic is free in the App Store build and includes clipboard history for up to 50 items, standard paste, search, filtering, pinning, screenshot capture into history, excluded apps, auto-delete, optional private iCloud sync, and privacy-first defaults. Pro is purchased in the App Store as a one-time non-consumable in-app purchase and unlocks OCR capture, unlimited history, Touch ID lock, encryption, paste tools, paste stack, snippets, notes, rules, and export/import. No external checkout or license keys are used in this build. The standard App Review flow does not require Accessibility or Apple Events permissions. To test Basic: copy text in TextEdit or Safari, open history with Cmd+Shift+Control+Y, select the item, then paste manually with Cmd+V. Screenshot capture is available in Basic; OCR is a visible locked Pro surface. To find the durable purchase path after onboarding, open Settings > License and tap Unlock Pro or Restore Purchases.
    ios: >-
      SaneClip for iPhone and iPad is a freemium App Store app. Basic is free in the App Store build and includes synced clipboard history, search, pinning, widgets, and Share Sheet saving. Pro is purchased in the App Store as a one-time non-consumable in-app purchase and unlocks Pro features. No external checkout or license keys are used in this build. The app does not request Accessibility, Apple Events, camera, microphone, or location permissions. Fastest review path: launch and leave onboarding visible, then inspect the optional Pro unlock on the final plan screen before tapping Continue. After onboarding, open Settings and return to a locked Pro surface in History or Pinned, then tap Unlock Pro. If no synced history exists, built-in demo history is shown for review.
  accessibility_declarations:
    publish: true
    families:
      mac:
        supports_dark_interface: true
      iphone:
        supports_dark_interface: true
        supports_sufficient_contrast: true
        supports_larger_text: true
        supports_voiceover: true
        supports_voice_control: true
        supports_differentiate_without_color_alone: true
        supports_reduced_motion: true
        supports_captions: false
        supports_audio_descriptions: false
      ipad:
        supports_dark_interface: true
        supports_sufficient_contrast: true
        supports_larger_text: true
        supports_voiceover: true
        supports_voice_control: true
        supports_differentiate_without_color_alone: true
        supports_reduced_motion: true
        supports_captions: false
        supports_audio_descriptions: false
  screenshots:
    macos: docs/images/appstore-mac-*.png
    ios: docs/images/screenshot-ios-*-dark.png
    ipad: docs/images/screenshot-ipad-*-dark.png
  strip_frameworks:
    - Sparkle.framework
  contact:
    name: "Stephan Joseph"
    phone: "+17277589785"
    email: "hi@saneapps.com"

website: true
website_domain: saneclip.com

setapp:
  enabled: true
  app_id: "1847"
  version_id: "47647"
  scheme: SaneClipSetapp
  configuration: Release-Setapp
  bundle_id: com.saneclip.app-setapp
  public_key_path: Setapp/setappPublicKey.pem
  release_notes_public: true
  review_comments_private: true
  require_manual_release_confirmation: true
  listing:
    setapp_url: "https://setapp.com/apps/saneclip"
    privacy_policy_url: "https://saneclip.com/privacy"
    support_url: "https://saneclip.com/support"
    screenshot_source: "owned-site app-in-use screenshots"
    screenshot_asset_root: docs/images/setapp
    screenshot_roles:
      - core_workflow_clipboard_history
      - core_workflow_clipboard_history_hero
      - privacy_touch_id_settings
      - productivity_snippets
      - private_storage
    screenshots:
      - docs/images/setapp/saneclip-setapp-01-clipboard-history.png
      - docs/images/setapp/saneclip-setapp-02-clipboard-history-hero.png
      - docs/images/setapp/saneclip-setapp-03-touch-id-privacy-settings.png
      - docs/images/setapp/saneclip-setapp-04-snippets.png
      - docs/images/setapp/saneclip-setapp-05-private-storage.png
  restrictions:
    no_sparkle: true
    no_direct_checkout: true
    no_license_keys: true
    no_donation_ui: true
    no_demo_or_trial_mode: true
