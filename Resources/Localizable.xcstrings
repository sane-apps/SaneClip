    "Pro keeps as much history as you configure, including unlimited.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pro keeps as much history as you configure, including unlimited."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Pro behält so viel Verlauf, wie du festlegst – auch unbegrenzt."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pro conserve autant d'historique que vous le configurez, y compris illimité."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Pro conserva todo el historial que configures, incluso ilimitado."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Pro conserva tutta la cronologia che configuri, anche illimitata."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Pro mantém quanto histórico você quiser, inclusive ilimitado."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Proでは無制限を含め、設定した分だけ履歴を保持できます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Pro 可按你的设置保留任意多的历史，包括无限制。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Pro는 무제한을 포함해 설정한 만큼 기록을 유지합니다."
          }
        }
      }
    },
