    "Bulk-delete disposable clips while keeping pinned, tagged, noted, and non-default collection items.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Bulk-delete disposable clips while keeping pinned, tagged, noted, and non-default collection items."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verwerfbare Clips sammelweise löschen, dabei angeheftete, getaggte, mit Notiz versehene und Objekte aus Nicht-Standard-Sammlungen behalten."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Supprime en masse les éléments jetables tout en conservant ceux épinglés, tagués, annotés et des collections non par défaut."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elimina en bloque los elementos desechables y conserva los fijados, etiquetados, con nota y de colecciones no predeterminadas."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Elimina in blocco gli elementi temporanei mantenendo quelli fissati, con tag, con note e nelle raccolte non predefinite."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Apaga em lote itens descartáveis, preservando os fixados, com etiqueta, com nota e de coleções não padrão."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ピン留め、タグ付き、メモ付き、デフォルト以外のコレクションの項目を残して、不要なクリップを一括削除します。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "批量删除可弃剪辑，同时保留已固定、带标签、带备注及非默认收藏集的项。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "고정, 태그, 메모, 기본 외 컬렉션 항목은 유지하면서 일회성 클립을 일괄 삭제합니다."
          }
        }
      }
    },
