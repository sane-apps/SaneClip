    "Share clipboard history across your Apple devices": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Share clipboard history across your Apple devices"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verlauf über deine Apple-Geräte hinweg teilen"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Partager l'historique du presse-papiers entre vos appareils Apple"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Comparte el historial del portapapeles entre tus dispositivos Apple"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Condividi la cronologia appunti tra i tuoi dispositivi Apple"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Compartilhar o histórico entre seus dispositivos Apple"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Appleデバイス間でクリップボード履歴を共有します"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在你的 Apple 设备间共享剪贴板历史"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple 기기 간에 클립보드 기록을 공유합니다"
          }
        }
      }
    },
    "This clears saved sync state on this device and reconnects to iCloud sync. Your local clipboard history stays on this device.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This clears saved sync state on this device and reconnects to iCloud sync. Your local clipboard history stays on this device."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dies löscht den gesicherten Sync-Status auf diesem Gerät und stellt die Verbindung zu iCloud-Sync wieder her. Dein lokaler Verlauf bleibt auf diesem Gerät."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela efface l'état de synchronisation enregistré sur cet appareil et se reconnecte à la synchronisation iCloud. Votre historique local du presse-papiers reste sur cet appareil."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto borra el estado de sincronización guardado en este dispositivo y reconecta con la sincronización de iCloud. Tu historial local del portapapeles permanece en este dispositivo."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo cancella lo stato di sincronizzazione salvato su questo dispositivo e si riconnette alla sincronizzazione iCloud. La cronologia locale resta su questo dispositivo."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Isto limpa o estado de sincronização salvo neste dispositivo e reconecta à sincronização do iCloud. Seu histórico local permanece neste dispositivo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "これにより、このデバイスに保存された同期状態が消去され、iCloud同期に再接続されます。ローカルのクリップボード履歴はこのデバイスに残ります。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这会清除此设备上已存的同步状态并重新连接到 iCloud 同步。你的本地剪贴板历史仍保留在此设备上。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 기기에 저장된 동기화 상태를 지우고 iCloud 동기화에 다시 연결합니다. 로컬 클립보드 기록은 이 기기에 남습니다."
          }
        }
      }
    },
