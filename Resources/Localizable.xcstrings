    "saneclip.settings.security.encrypt_history_pro_help": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Encrypts clipboard history on disk using AES-256-GCM — requires Pro"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verschlüsselt den Verlauf auf der Festplatte mit AES-256-GCM – erfordert Pro"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Chiffre l'historique du presse-papiers sur le disque en AES-256-GCM — nécessite Pro"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cifra el historial del portapapeles en el disco con AES-256-GCM — requiere Pro"
          }
