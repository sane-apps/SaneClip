    "Paste stack is empty. Turn on “Record copies” to build one as you copy, or use “Add to Paste Stack” on any clip.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Paste stack is empty. Turn on “Record copies” to build one as you copy, or use “Add to Paste Stack” on any clip."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Einfügestapel ist leer. Aktiviere „Kopien aufzeichnen“, um beim Kopieren einen aufzubauen, oder verwende „Zum Einfügestapel hinzufügen“ bei einem Clip."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La pile de collage est vide. Activez « Enregistrer les copies » pour la remplir au fur et à mesure, ou utilisez « Ajouter à la pile de collage » sur n'importe quel élément."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La pila de pegado está vacía. Activa «Grabar copias» para crearla mientras copias, o usa «Añadir a la pila de pegado» en cualquier elemento."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La pila di incollaggio è vuota. Attiva “Registra copie” per crearla man mano che copi, oppure usa “Aggiungi alla pila di incollaggio” su qualsiasi elemento."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A pilha de colagem está vazia. Ative “Gravar cópias” para montá-la conforme copia, ou use “Adicionar à pilha de colagem” em qualquer item."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ペーストスタックは空です。「コピーを記録」をオンにするとコピーしながら作成できます。または任意のクリップで「ペーストスタックに追加」を使ってください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "粘贴栈为空。开启“记录拷贝”以在拷贝时自动构建，或对任意剪辑使用“加入粘贴栈”。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "붙여넣기 스택이 비어 있습니다. 복사하면서 스택을 만들려면 “복사본 기록”을 켜거나, 클립에서 “붙여넣기 스택에 추가”를 사용하세요."
          }
        }
      }
    },
