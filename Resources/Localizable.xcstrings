    "saneclip.settings.security.authenticate_disable_history_encryption": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Authenticate to disable history encryption"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Authentifizieren, um Verlaufsverschlüsselung zu deaktivieren"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Authentifiez-vous pour désactiver le chiffrement de l'historique"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Autentícate para desactivar el cifrado del historial"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Autenticati per disattivare la cifratura della cronologia"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Autentique-se para desativar a criptografia do histórico"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "認証して履歴の暗号化を無効にする"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "验证身份以停用历史加密"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "기록 암호화를 끄려면 인증하세요"
          }
        }
      }
    },
